<?php
/**
 * Asterisk Config Sync Functions
 * 
 * Handles pushing extension config to Asterisk when admin saves in FA
 */

function sync_extension_to_asterisk(array $extension): bool
{
    global $db;
    
    $ami_host = get_asterisk_host();
    $ami_port = get_asterisk_port();
    $ami_user = get_asterisk_admin_user();
    $ami_pass = get_asterisk_admin_pass();
    
    if (!$ami_host || !$ami_user) {
        error_log("Asterisk config sync: Missing AMI credentials");
        return false;
    }
    
    $ami = new \Ksfraser\AsteriskPBX\Integration\AsteriskAMI($ami_host, $ami_port, $ami_user, $ami_pass);
    
    if (!$ami->connect()) {
        error_log("Asterisk config sync: Cannot connect to AMI");
        return false;
    }
    
    // Generate SIP peer config for this extension
    $sip_config = generate_sip_peer_config($extension);
    
    // Write to Asterisk config directory
    $sip_file = get_asterisk_config_dir() . '/sip_additional_' . $extension['extension'] . '.conf';
    file_put_contents($sip_file, $sip_config);
    
    // Reload Asterisk SIP module via AMI
    $ami->sendCommand("Action: Command\r\nCommand: sip reload\r\n\r\n");
    
    $ami->disconnect();
    
    return true;
}

function generate_sip_peer_config(array $ext): string
{
    $name = $ext['extension'];
    $email = $ext['email'] ?? '';
    $forward = $ext['forward_to'] ?? '';
    
    $config = <<<CONFIG
; Extension {$name} - Auto-generated by FA
[{$name}]
type=friend
host=dynamic
secret={$ext['sip_peer'] ?: 'changeme'}
context=from-internal
deny=0.0.0.0/0.0.0.0
permit=0.0.0.0/0.0.0.0
callgroup=
pickupgroup=
callerid=name <{$name}>
CONFIG;

    if ($email) {
        $config .= "\nmailbox={$name}@default";
    }
    
    if ($forward) {
        $config .= "\nforwardto={$forward}";
    }
    
    $config .= "\ndtmfmode=rfc2833\n";
    
    return $config;
}

function remove_extension_from_asterisk(string $extension): bool
{
    $sip_file = get_asterisk_config_dir() . '/sip_additional_' . $extension . '.conf';
    
    if (file_exists($sip_file)) {
        unlink($sip_file);
    }
    
    // Reload SIP
    $ami_host = get_asterisk_host();
    $ami = new \Ksfraser\AsteriskPBX\Integration\AsteriskAMI($ami_host, get_asterisk_port(), get_asterisk_admin_user(), get_asterisk_admin_pass());
    
    if ($ami->connect()) {
        $ami->sendCommand("Action: Command\r\nCommand: sip reload\r\n\r\n");
        $ami->disconnect();
    }
    
    return true;
}

function check_asterisk_connection(): bool
{
    $ami_host = get_asterisk_host();
    $ami_port = get_asterisk_port();
    
    if (!$ami_host) {
        return false;
    }
    
    $socket = @fsockopen($ami_host, $ami_port, $errno, $errstr, 3);
    
    if ($socket) {
        fclose($socket);
        return true;
    }
    
    return false;
}

// Settings retrieval
function get_asterisk_host(): string
{
    global $db;
    $sql = "SELECT value FROM " . TB_PREF . "sys_prefs WHERE name = 'asterisk_host'";
    $result = $db->query($sql);
    if ($result && $db->num_rows($result) > 0) {
        $row = $db->fetch($result);
        return $row['value'];
    }
    return '';
}

function get_asterisk_port(): int
{
    global $db;
    $sql = "SELECT value FROM " . TB_PREF . "sys_prefs WHERE name = 'asterisk_port'";
    $result = $db->query($sql);
    if ($result && $db->num_rows($result) > 0) {
        $row = $db->fetch($result);
        return (int)$row['value'];
    }
    return 5038;
}

function get_asterisk_admin_user(): string
{
    global $db;
    $sql = "SELECT value FROM " . TB_PREF . "sys_prefs WHERE name = 'asterisk_admin_user'";
    $result = $db->query($sql);
    if ($result && $db->num_rows($result) > 0) {
        $row = $db->fetch($result);
        return $row['value'];
    }
    return '';
}

function get_asterisk_admin_pass(): string
{
    global $db;
    $sql = "SELECT value FROM " . TB_PREF . "sys_prefs WHERE name = 'asterisk_admin_pass'";
    $result = $db->query($sql);
    if ($result && $db->num_rows($result) > 0) {
        $row = $db->fetch($result);
        return $row['value'];
    }
    return '';
}

function get_asterisk_config_dir(): string
{
    global $db;
    $sql = "SELECT value FROM " . TB_PREF . "sys_prefs WHERE name = 'asterisk_config_dir'";
    $result = $db->query($sql);
    if ($result && $db->num_rows($result) > 0) {
        $row = $db->fetch($result);
        return $row['value'];
    }
    return '/etc/asterisk';
}

function save_asterisk_settings(string $host, int $port, string $user, string $pass, string $config_dir): bool
{
    global $db;
    
    $settings = [
        'asterisk_host' => $host,
        'asterisk_port' => $port,
        'asterisk_admin_user' => $user,
        'asterisk_admin_pass' => $pass,
        'asterisk_config_dir' => $config_dir,
    ];
    
    foreach ($settings as $name => $value) {
        $sql = "INSERT INTO " . TB_PREF . "sys_prefs (name, value) VALUES (" . $db->escape($name) . ", " . $db->escape($value) . ")
            ON DUPLICATE KEY UPDATE value = " . $db->escape($value);
        $db->query($sql);
    }
    
    return true;
}